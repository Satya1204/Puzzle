<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement name="pane" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); height: 40px;">
        <ui:VisualElement name="row1" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); flex-direction: row; height: 20px; justify-content: space-between; align-items: center;">
            <ui:Label text="Position" style="flex-grow: 0;" />
            <uie:PropertyField binding-path="position" name="pos" style="margin-right: -5px; flex-grow: 1; max-width: initial;" />
            <ui:EnumField binding-path="mode" name="mode" style="flex-grow: 1; max-width: 100px; padding-left: 5px;" />
        </ui:VisualElement>
        <ui:VisualElement name="row2" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); flex-direction: row; height: 20px; justify-content: space-between; align-items: center;">
            <ui:Label text="CP1" style="flex-grow: 0;" />
            <uie:PropertyField binding-path="leftControlPoint" name="cp1" style="width: 50%; margin-right: 0; margin-left: 0; flex-grow: 0; padding-right: 0;" />
            <ui:Label text="CP2" style="flex-grow: 0; padding-left: 2px;" />
            <uie:PropertyField binding-path="rightControlPoint" name="cp2" style="width: 50%; margin-right: 0; margin-left: 5px; flex-grow: 0;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
